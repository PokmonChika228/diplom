PORT=5000
NODE_ENV=production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Replit предоставляет автоматически. Для локального запуска:
DATABASE_URL=postgresql://user:password@localhost:5432/zhuchy

# ── Сессия ────────────────────────────────────────────────────────────────────
SESSION_SECRET=замените_на_случайную_строку_минимум_32_символа

# ── Админ-панель ──────────────────────────────────────────────────────────────
ADMIN_LOGIN=admin
ADMIN_PASSWORD=замените_на_надёжный_пароль

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Создайте пароль приложения: myaccount.google.com → Безопасность → Пароли приложений
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=zhuchymvp@gmail.com
SMTP_FROM="ZHUCHY club" <zhuchymvp@gmail.com>
SMTP_PASS=здесь_пароль_приложения_gmail   # → хранить в Replit Secrets

# ── ЮKassa ────────────────────────────────────────────────────────────────────
# Получить: yookassa.ru → Настройки → Ключи API
YOOKASSA_SHOP_ID=ваш_shop_id
YOOKASSA_SECRET_KEY=ваш_секретный_ключ    # → хранить в Replit Secrets

# ── Cloudinary (загрузка изображений, опционально) ────────────────────────────
# Без этих переменных изображения хранятся локально в /uploads
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
