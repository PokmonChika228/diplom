PORT=8080
NODE_ENV=production
# Optional: absolute path to persistent database file (recommended on hosting)
# DB_PATH=/var/data/site-db.json
# Netlify Blobs store name for persistent data on Netlify
# NETLIFY_BLOBS_STORE=site-db
# Optional manual Blobs configuration (if auto-context is unavailable)
# NETLIFY_BLOBS_SITE_ID=your_site_id
# NETLIFY_BLOBS_TOKEN=your_personal_access_token

# Admin login credentials
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me_please

# Better option than ADMIN_PASSWORD: set bcrypt hash
# ADMIN_PASSWORD_HASH=$2b$10$replace_with_bcrypt_hash

# Must be a long random string in production
SESSION_SECRET=change_this_session_secret_for_production

# Cloudinary (required for image upload in Netlify admin panel)
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# or set 3 vars below:
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
